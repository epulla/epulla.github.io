---
// components/SlideMenu.astro
// Drawer con navegación rápida a cualquier slide

interface Props {
  totalSlides: number; // número de slides de eventos (sin contar la cover)
}

const { totalSlides } = Astro.props;
---

<!-- Botón hamburguesa (oculto hasta desbloquear) -->
<button
  id="menu-toggle"
  class="menu-toggle"
  aria-label="Menú de slides"
  style="display:none"
>
  <span></span>
  <span></span>
  <span></span>
</button>

<!-- Drawer -->
<div id="slide-drawer" class="drawer" aria-hidden="true">
  <div class="drawer-backdrop"></div>
  <div class="drawer-panel">
    <div class="drawer-header">
      <h2 class="drawer-title">Nuestros momentos</h2>
      <button id="drawer-close" class="drawer-close" aria-label="Cerrar"
        >✕</button
      >
    </div>
    <div class="drawer-grid">
      {
        Array.from({ length: totalSlides }, (_, i) => (
          <button
            class="slide-chip"
            data-target={i + 1}
            aria-label={`Ir al slide ${i + 1}`}
          >
            <span class="chip-number">{i + 1}</span>
          </button>
        ))
      }
    </div>
  </div>
</div>

<style>
  /* ── Hamburguesa ── */
  .menu-toggle {
    position: fixed;
    top: 1.4rem;
    right: 1.6rem;
    z-index: 50;
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid var(--border);
    border-radius: 8px;
    width: 42px;
    height: 42px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 5px;
    cursor: pointer;
    backdrop-filter: blur(8px);
    transition:
      background 0.2s,
      border-color 0.2s;
    padding: 0;
  }

  .menu-toggle:hover {
    background: rgba(224, 64, 251, 0.15);
    border-color: var(--magenta);
  }

  .menu-toggle span {
    display: block;
    width: 18px;
    height: 1.5px;
    background: var(--text);
    border-radius: 2px;
    transition:
      transform 0.3s,
      opacity 0.3s;
  }

  /* Estado abierto */
  .menu-toggle.is-open span:nth-child(1) {
    transform: translateY(6.5px) rotate(45deg);
  }
  .menu-toggle.is-open span:nth-child(2) {
    opacity: 0;
    transform: scaleX(0);
  }
  .menu-toggle.is-open span:nth-child(3) {
    transform: translateY(-6.5px) rotate(-45deg);
  }

  /* ── Drawer ── */
  .drawer {
    position: fixed;
    inset: 0;
    z-index: 150;
    pointer-events: none;
    visibility: hidden;
  }

  .drawer[aria-hidden="false"] {
    pointer-events: all;
    visibility: visible;
  }

  .drawer-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(8, 0, 18, 0.72);
    backdrop-filter: blur(10px);
    opacity: 0;
    transition: opacity 0.3s;
  }

  .drawer[aria-hidden="false"] .drawer-backdrop {
    opacity: 1;
  }

  .drawer-panel {
    position: absolute;
    top: 0;
    right: 0;
    width: min(360px, 92vw);
    height: 100%;
    background: rgba(18, 0, 28, 0.96);
    border-left: 1px solid rgba(224, 64, 251, 0.18);
    box-shadow: -8px 0 60px rgba(224, 64, 251, 0.12);
    display: flex;
    flex-direction: column;
    gap: 0;
    transform: translateX(100%);
    transition: transform 0.4s cubic-bezier(0.77, 0, 0.18, 1);
    overflow-y: auto;
  }

  .drawer[aria-hidden="false"] .drawer-panel {
    transform: translateX(0);
  }

  .drawer-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.8rem 1.6rem 1.2rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
    flex-shrink: 0;
  }

  .drawer-title {
    font-family: "Cormorant Garamond", serif;
    font-size: 1.3rem;
    font-weight: 300;
    font-style: italic;
    background: linear-gradient(120deg, var(--magenta), var(--gold));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .drawer-close {
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid var(--border);
    color: var(--text);
    width: 30px;
    height: 30px;
    border-radius: 50%;
    cursor: pointer;
    font-size: 0.8rem;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    transition: background 0.2s;
  }
  .drawer-close:hover {
    background: var(--magenta);
    color: #fff;
  }

  /* ── Grid de cuadritos ── */
  .drawer-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0.75rem;
    padding: 1.6rem;
  }

  .slide-chip {
    aspect-ratio: 1;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition:
      background 0.2s,
      border-color 0.2s,
      transform 0.2s;
    position: relative;
    overflow: hidden;
  }

  .slide-chip::before {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(224, 64, 251, 0.15), transparent);
    opacity: 0;
    transition: opacity 0.2s;
  }

  .slide-chip:hover {
    background: rgba(224, 64, 251, 0.12);
    border-color: var(--magenta);
    transform: scale(1.05);
  }

  .slide-chip:hover::before {
    opacity: 1;
  }

  .slide-chip.is-active {
    background: rgba(224, 64, 251, 0.2);
    border-color: var(--magenta);
    box-shadow: 0 0 16px rgba(224, 64, 251, 0.3);
  }

  .chip-number {
    font-family: "Cinzel", serif;
    font-size: 1rem;
    color: var(--text);
    position: relative;
    z-index: 1;
  }

  .slide-chip.is-active .chip-number {
    color: var(--gold);
  }

  /* scrollbar */
  .drawer-panel::-webkit-scrollbar {
    width: 3px;
  }
  .drawer-panel::-webkit-scrollbar-track {
    background: transparent;
  }
  .drawer-panel::-webkit-scrollbar-thumb {
    background: var(--purple);
    border-radius: 2px;
  }
</style>

<script type="module">
  import { gsap } from "https://cdn.jsdelivr.net/npm/gsap@3.12.5/+esm";

  const toggle = document.getElementById("menu-toggle");
  const drawer = document.getElementById("slide-drawer");
  const backdrop = drawer.querySelector(".drawer-backdrop");
  const closeBtn = document.getElementById("drawer-close");
  const chips = drawer.querySelectorAll(".slide-chip");

  let isOpen = false;

  /* ── Mostrar botón hamburguesa al desbloquear ── */
  window.addEventListener("timeline:unlock", () => {
    toggle.style.display = "flex";
    gsap.fromTo(
      toggle,
      { opacity: 0, scale: 0.7 },
      { opacity: 1, scale: 1, duration: 0.5, ease: "back.out(2)" },
    );
  });

  /* ── Abrir / cerrar ── */
  function openDrawer() {
    isOpen = true;
    drawer.setAttribute("aria-hidden", "false");
    toggle.classList.add("is-open");
  }

  function closeDrawer() {
    isOpen = false;
    drawer.setAttribute("aria-hidden", "true");
    toggle.classList.remove("is-open");
  }

  toggle.addEventListener("click", () =>
    isOpen ? closeDrawer() : openDrawer(),
  );
  closeBtn.addEventListener("click", closeDrawer);
  backdrop.addEventListener("click", closeDrawer);
  window.addEventListener("keydown", (e) => {
    if (e.key === "Escape" && isOpen) closeDrawer();
  });

  /* ── Chip activo ── */
  function setActiveChip(slideIdx) {
    chips.forEach((c) =>
      c.classList.toggle("is-active", Number(c.dataset.target) === slideIdx),
    );
  }

  /* ── Clic en chip → navegar ── */
  chips.forEach((chip) => {
    chip.addEventListener("click", () => {
      const target = Number(chip.dataset.target);
      window.dispatchEvent(
        new CustomEvent("timeline:goTo", { detail: { slideIndex: target } }),
      );
      closeDrawer();
    });
  });

  /* ── Sincronizar chip activo cuando cambia el slide ── */
  window.addEventListener("timeline:slideEnter", (e) => {
    setActiveChip(e.detail.slideIndex);
  });

  /* ── Hover en close con GSAP ── */
  closeBtn.addEventListener("mouseenter", () =>
    gsap.to(closeBtn, { rotate: 90, duration: 0.3, ease: "power2.out" }),
  );
  closeBtn.addEventListener("mouseleave", () =>
    gsap.to(closeBtn, { rotate: 0, duration: 0.3, ease: "power2.out" }),
  );
</script>
